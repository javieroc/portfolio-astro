---
// Stripe Buy Button — no backend required, works on static hosting.
//
// Steps to get your values from the Stripe Dashboard:
//   1. Go to https://dashboard.stripe.com/payment-links and create a Payment Link
//      (or use an existing one) with the donation amount(s) you want.
//   2. On the Payment Link detail page, click "Buy button" → copy the two values below.
//
// Replace the placeholder strings with your real values:
const BUY_BUTTON_ID   = 'buy_btn_1TMpFz1lDmBh2mHNC0s56T4N';
const PUBLISHABLE_KEY = 'pk_live_51Ro7J91lDmBh2mHNs4Sd3rxEm2fjSnXUZ1hZyuavAgJ8djxnhI6vO1qJ3E1FCN7oT0HW8RZZghjLNgz4gTEaB8ac00ZGt5sxeR';
---

<!-- Modal backdrop + card -->
<div
  id="donation-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Support Javier"
  class="hidden fixed inset-0 z-[200] flex items-center justify-center p-4"
>
  <!-- Backdrop -->
  <div id="donation-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Card -->
  <div class="relative z-10 bg-white rounded-2xl shadow-2xl p-8 w-full max-w-sm flex flex-col items-center gap-6">
    <button
      id="donation-close"
      class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors"
      aria-label="Close"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <div class="flex flex-col items-center gap-1 text-center">
      <svg class="w-8 h-8" style="fill: #345988" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
      <h2 class="text-lg font-semibold text-gray-800">Support my work</h2>
      <p class="text-sm text-gray-500">If you enjoy my projects, a small donation keeps the servers running.</p>
    </div>

    <!-- Stripe Buy Button widget (loaded on demand by the script below) -->
    <div id="stripe-widget-mount"></div>
  </div>
</div>

<script define:vars={{ BUY_BUTTON_ID, PUBLISHABLE_KEY }}>
  const modal    = document.getElementById('donation-modal');
  const backdrop = document.getElementById('donation-backdrop');
  const closeBtn = document.getElementById('donation-close');
  const mount    = document.getElementById('stripe-widget-mount');

  let widgetLoaded = false;

  function loadStripeWidget() {
    if (widgetLoaded) return;
    widgetLoaded = true;

    const script = document.createElement('script');
    script.src   = 'https://js.stripe.com/v3/buy-button.js';
    script.async = true;
    script.onload = () => {
      const widget = document.createElement('stripe-buy-button');
      widget.setAttribute('buy-button-id', BUY_BUTTON_ID);
      widget.setAttribute('publishable-key', PUBLISHABLE_KEY);
      mount.appendChild(widget);
    };
    document.head.appendChild(script);
  }

  function openModal() {
    loadStripeWidget();
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // All elements with data-donate-trigger open the modal
  document.querySelectorAll('[data-donate-trigger]').forEach(el => {
    el.addEventListener('click', openModal);
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
