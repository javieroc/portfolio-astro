---
import { Mail, Linkedin, Github, Phone, MapPin } from '@lucide/astro';
---

<section id="contact" class="py-24 px-4 sm:px-6">
	<div class="container mx-auto text-center">
		<h2 class="text-3xl text-arctic font-bold text-center mb-2 tracking-wide reveal">
			Get in Touch
		</h2>
		<div class="w-12 h-0.5 bg-glacier mx-auto mb-12 reveal" style="transition-delay: 0.1s"></div>

		<div class="max-w-lg mx-auto reveal" style="transition-delay: 0.2s">
			<div
				class="bg-white border border-mist/60 p-6 sm:p-10"
				style="box-shadow: 0 4px 24px rgba(52, 89, 136, 0.06);"
			>
				<p class="text-slate leading-relaxed mb-8 text-base">
					Whether you have a project in mind, want to collaborate, or just want to say hello —
					my inbox is open.
				</p>

				<div class="flex flex-col items-center gap-4 text-sm">

					<a
						href="mailto:ferroxido@gmail.com"
						class="group flex items-center gap-3 text-glacier hover:text-arctic transition-colors duration-300"
					>
						<Mail class="w-4 h-4 flex-shrink-0" />
						<span class="border-b border-transparent group-hover:border-arctic transition-all duration-300 tracking-wide">
							ferroxido@gmail.com
						</span>
					</a>

					<a
						href="tel:+353873837850"
						class="group flex items-center gap-3 text-glacier hover:text-arctic transition-colors duration-300"
					>
						<Phone class="w-4 h-4 flex-shrink-0" />
						<span class="border-b border-transparent group-hover:border-arctic transition-all duration-300 tracking-wide">
							+353 087 383 7850
						</span>
					</a>

					<div class="flex items-center gap-3 text-mist">
						<MapPin class="w-4 h-4 flex-shrink-0" />
						<span class="tracking-wide">Dublin, Ireland</span>
					</div>

				</div>

				<div class="flex items-center justify-center gap-6 mt-8 pt-6 border-t border-mist/30">
					<a
						href="https://github.com/javieroc"
						target="_blank"
						aria-label="GitHub"
						class="text-mist hover:text-arctic transition-all duration-300 hover:scale-110"
					>
						<Github class="w-5 h-5" />
					</a>
					<a
						href="https://www.linkedin.com/in/ocampojavieralfonso/"
						target="_blank"
						aria-label="LinkedIn"
						class="text-mist hover:text-arctic transition-all duration-300 hover:scale-110"
					>
						<Linkedin class="w-5 h-5" />
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
