---
import { Linkedin, Github, Mail, FileText } from '@lucide/astro';
import Avatar from '../components/Avatar.astro';
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden">

  <!-- Background image with slow Ken Burns zoom -->
  <img
    src="/portfolio-astro/wallpaper.jpg"
    alt=""
    aria-hidden="true"
    class="hero-img absolute inset-0 w-full h-full object-cover object-center"
  />

  <!-- Overlay 1: arctic blue tint to unify with palette -->
  <div class="absolute inset-0 bg-arctic/50"></div>

  <!-- Overlay 2: vignette depth -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at center, transparent 40%, rgba(20, 42, 80, 0.55) 100%);"
  ></div>

  <!-- Overlay 3: bottom fade into the page -->
  <div
    class="absolute bottom-0 left-0 right-0 h-48"
    style="background: linear-gradient(to bottom, transparent, #F3F5F9);"
  ></div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto px-4 sm:px-6 pt-28 pb-32 flex flex-col items-center text-center">

    <!-- Avatar -->
    <div class="mb-8 hero-fade" style="--delay: 0s">
      <Avatar src="/portfolio-astro/avatar.jpeg" size="large" />
    </div>

    <!-- Frosted glass nameplate -->
    <div
      class="nameplate w-auto px-6 sm:px-10 md:px-14 py-6 mb-6 hero-fade"
      style="--delay: 0.15s"
    >
      <h1 class="whitespace-nowrap text-2xl sm:text-4xl md:text-6xl font-bold tracking-[0.05em] sm:tracking-[0.15em] md:tracking-[0.2em] text-white mb-4">
        JAVIER OCAMPO
      </h1>
      <div class="w-12 h-px bg-white/40 mx-auto mb-4"></div>
      <p class="text-xs tracking-[0.25em] sm:tracking-[0.35em] text-white/70 uppercase">
        Fullstack Developer
      </p>
    </div>

    <!-- Bio -->
    <p class="text-base md:text-lg text-white/65 max-w-xs sm:max-w-sm md:max-w-md leading-relaxed mb-10 hero-fade" style="--delay: 0.3s">
      Building purposeful web applications from the ground up.
      Based in Dublin, Ireland.
    </p>

    <!-- Social links -->
    <div class="flex items-center gap-6 sm:gap-8 hero-fade" style="--delay: 0.45s">
      <a href="https://github.com/javieroc" target="_blank" aria-label="GitHub"
        class="text-white/55 hover:text-white transition-all duration-300 hover:scale-110 hover:-translate-y-0.5">
        <Github class="w-7 h-7" />
      </a>
      <a href="https://www.linkedin.com/in/ocampojavieralfonso/" target="_blank" aria-label="LinkedIn"
        class="text-white/55 hover:text-white transition-all duration-300 hover:scale-110 hover:-translate-y-0.5">
        <Linkedin class="w-7 h-7" />
      </a>
      <a href="mailto:ferroxido@gmail.com" aria-label="Email"
        class="text-white/55 hover:text-white transition-all duration-300 hover:scale-110 hover:-translate-y-0.5">
        <Mail class="w-7 h-7" />
      </a>
      <a href="/portfolio-astro/Javier_Ocampo_CV.pdf" download aria-label="Download CV"
        class="text-white/55 hover:text-white transition-all duration-300 hover:scale-110 hover:-translate-y-0.5">
        <FileText class="w-7 h-7" />
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 scroll-hint hero-fade" style="--delay: 0.7s">
    <div class="flex flex-col items-center gap-1.5">
      <span class="text-[10px] tracking-[0.3em] text-white/30 uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
    </div>
  </div>

</section>

<style>
  /* Ken Burns slow zoom */
  @keyframes ken-burns {
    0%   { transform: scale(1)    translateY(0); }
    100% { transform: scale(1.08) translateY(-1%); }
  }
  .hero-img {
    animation: ken-burns 22s ease-out forwards;
    transform-origin: center top;
  }

  /* Frosted glass nameplate */
  .nameplate {
    background: rgba(52, 89, 136, 0.18);
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow:
      0 8px 32px rgba(20, 42, 80, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  /* Hero content entrance animation */
  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero-fade {
    opacity: 0;
    animation: hero-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  /* Scroll hint bob */
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }
  .scroll-hint {
    animation: hero-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.7s forwards,
               bob 2.4s ease-in-out 1.8s infinite;
  }
</style>
