---
interface Props {
	src: string;
	size: 'small' | 'medium' | 'large';
}

const { src, size } = Astro.props;
const sizeClass = {
	small: 'w-24 h-24',
	medium: 'w-32 h-32',
	large: 'w-40 h-40'
}[size] || 'w-32 h-32';

const _class = `${sizeClass} rounded-full object-cover ring-2 ring-mist ring-offset-4 ring-offset-frost`;
---
<img class={_class} src={src} alt="Javier Ocampo" loading="lazy">
